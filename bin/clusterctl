#!/usr/bin/env python3
"""
clusterctl — single-file CLI for the spids dev cluster.

Manages a dynamic list of AI nodes (slaves + master) defined in a TOML
config file. Supports CRUD operations on nodes, plus health checks and
keyword-routed ask execution.

Usage:
  clusterctl health
  clusterctl route "task text"
  clusterctl ask "task text"
  clusterctl nodes list
  clusterctl nodes add <name> [--host 1.2.3.4] [--port 11434] [--model X]
                            [--protocol ollama] [--role chat_reflection] [--timeout 120]
                            [--base-url http://...]
  clusterctl nodes remove <name>
  clusterctl nodes enable <name>
  clusterctl nodes disable <name>
  clusterctl nodes get <name>

Config file format (TOML):
  [meta]
  name = "spids-dev-cluster"
  config_path = "/home/spids/cluster/cluster.toml"   # default
  ...
  [[node]]
  name = "slave-a"
  role = "chat_reflection"            # or "code_tools" / "general" / custom
  host = "192.168.1.123"
  port = 11434                        # optional
  base_url = ""                       # optional, overrides host+port
  protocol = "ollama"                 # ollama | lmstudio | hermes | openai | custom
  model = "gemma4:12b-mlx"
  timeout_s = 120
  enabled = true
"""
from __future__ import annotations

import argparse
import json
import logging
import os
import re
import sys
import time
import unicodedata
import urllib.error
import urllib.request
from pathlib import Path

# Hindsight client is optional — if it fails to import, clusterctl still works
# (just no memory features).
try:
    sys.path.insert(0, str(Path(__file__).parent))
    import hindsight_client as hindsight
    HINDSIGHT_ENABLED = True
except Exception as _e:
    HINDSIGHT_ENABLED = False
    print(f"clusterctl: hindsight_client unavailable ({_e})", file=sys.stderr)

try:
    import tomllib  # py3.11+
except ModuleNotFoundError:
    sys.exit("clusterctl requires Python 3.11+ (uses tomllib)")

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(name)s] %(message)s")
log = logging.getLogger("clusterctl")

CONFIG_PATH = Path(os.environ.get("CLUSTER_CONFIG", "/home/spids/cluster/cluster.toml"))
LOG_PATH = Path("/home/spids/cluster/logs/ask.log")

VALID_PROTOCOLS = {"ollama", "lmstudio", "hermes", "openai", "custom"}
VALID_ROLES = {"chat_reflection", "code_tools", "general", "master"}


# =====================
# Config load/save
# =====================
def load_config() -> dict:
    if not CONFIG_PATH.exists():
        return {"meta": {"name": "spids-dev-cluster"}, "node": []}
    with CONFIG_PATH.open("rb") as f:
        return tomllib.load(f)


def save_config(cfg: dict) -> None:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    # Manual TOML writer (stdlib tomllib is read-only)
    lines = []
    if "meta" in cfg:
        lines.append("[meta]")
        for k, v in cfg["meta"].items():
            lines.append(f'{k} = {toml_value(v)}')
        lines.append("")
    nodes = cfg.get("node", [])
    for node in nodes:
        lines.append("[[node]]")
        for k, v in node.items():
            lines.append(f'{k} = {toml_value(v)}')
        lines.append("")
    CONFIG_PATH.write_text("\n".join(lines))


def toml_value(v) -> str:
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, (int, float)):
        return str(v)
    if isinstance(v, str):
        return json.dumps(v)  # safe escaping
    return json.dumps(v)


def get_node(cfg: dict, name: str) -> dict | None:
    for n in cfg.get("node", []):
        if n.get("name") == name:
            return n
    return None


def add_node(cfg: dict, **kwargs) -> dict:
    name = kwargs.get("name")
    if not name:
        raise ValueError("name is required")
    if get_node(cfg, name) is not None:
        raise ValueError(f"node {name!r} already exists")
    protocol = kwargs.get("protocol", "custom")
    if protocol not in VALID_PROTOCOLS:
        raise ValueError(f"protocol must be one of {sorted(VALID_PROTOCOLS)}")
    role = kwargs.get("role", "general")
    if role not in VALID_ROLES:
        raise ValueError(f"role must be one of {sorted(VALID_ROLES)}")
    node = {
        "name": name,
        "role": role,
        "host": kwargs.get("host", "127.0.0.1"),
        "port": int(kwargs.get("port", 0)) or None,
        "base_url": kwargs.get("base_url", "") or None,
        "protocol": protocol,
        "model": kwargs.get("model", "") or None,
        "timeout_s": int(kwargs.get("timeout_s", 120)),
        "enabled": bool(kwargs.get("enabled", True)),
    }
    # Optional auth token (only included if non-empty)
    token = kwargs.get("token", "").strip() if kwargs.get("token") else ""
    if token:
        node["token"] = token
    # Strip None values
    node = {k: v for k, v in node.items() if v is not None}
    cfg.setdefault("node", []).append(node)
    save_config(cfg)
    return node


def remove_node(cfg: dict, name: str) -> bool:
    nodes = cfg.get("node", [])
    for i, n in enumerate(nodes):
        if n.get("name") == name:
            del nodes[i]
            save_config(cfg)
            return True
    return False


def set_node_enabled(cfg: dict, name: str, enabled: bool) -> dict | None:
    n = get_node(cfg, name)
    if n is None:
        return None
    n["enabled"] = enabled
    save_config(cfg)
    return n


def resolve_base_url(node: dict) -> str:
    if node.get("base_url"):
        return node["base_url"].rstrip("/")
    host = node.get("host", "127.0.0.1")
    port = node.get("port")
    proto = node.get("protocol", "custom")
    if port:
        return f"{proto}://{host}:{port}"
    return f"{proto}://{host}"


# =====================
# Auth headers
# =====================
def _auth_headers(node: dict) -> dict:
    """Return Authorization headers for a node. If the node has a 'token' field,
    uses Bearer auth. Empty dict otherwise (for unauthenticated local nodes)."""
    token = node.get("token", "").strip()
    if token:
        return {"Authorization": f"Bearer {token}"}
    return {}


def _endpoint_url(base: str, suffix: str) -> str:
    """Build a URL by appending `suffix` to `base`, but only if `base` doesn't
    already end with the suffix's first path segment. This handles the case
    where the user has configured `base_url = "http://...:1234/v1"` (e.g. for
    LM Studio, OpenAI-compatible servers) — we must not double the /v1.

    Examples:
        base = "http://x:1234",         suffix = "/v1/models"  -> "http://x:1234/v1/models"
        base = "http://x:1234/v1",      suffix = "/v1/models"  -> "http://x:1234/v1/models"
        base = "http://x:11434",        suffix = "/api/tags"   -> "http://x:11434/api/tags"
        base = "http://x:1234/v1",      suffix = "/chat/completions" -> "http://x:1234/v1/chat/completions"
    """
    base = base.rstrip("/")
    suffix = suffix if suffix.startswith("/") else "/" + suffix
    # Extract the first path segment of the suffix
    suffix_first_segment = "/" + suffix.lstrip("/").split("/")[0]
    if base.endswith(suffix_first_segment):
        return base + suffix[len(suffix_first_segment):]
    return base + suffix


# =====================
# Health check
# =====================
def check_node(node: dict) -> dict:
    base = resolve_base_url(node)
    proto = node.get("protocol", "custom")
    timeout = node.get("timeout_s", 120)
    auth = _auth_headers(node)
    t0 = time.time()
    try:
        if proto == "ollama":
            url = _endpoint_url(base, "/api/tags")
        elif proto in ("lmstudio", "openai"):
            url = _endpoint_url(base, "/v1/models")
        else:
            url = _endpoint_url(base, "/")  # custom: just probe root
        req = urllib.request.Request(url, headers=auth)
        with urllib.request.urlopen(req, timeout=5) as r:
            body = r.read()
        latency_ms = round((time.time() - t0) * 1000, 1)
        model_available = False
        try:
            payload = json.loads(body)
            if proto in ("ollama",):
                names = [m.get("name") for m in payload.get("models", [])]
            elif proto in ("lmstudio", "openai"):
                names = [m.get("id") for m in payload.get("data", [])]
            else:
                names = []
            model_available = node.get("model", "") in names if node.get("model") else True
        except (ValueError, KeyError):
            names = []
        out = {
            "name": node.get("name"),
            "host": node.get("host"),
            "protocol": proto,
            "model": node.get("model", ""),
            "ok": True,
            "latency_ms": latency_ms,
            "model_available": model_available,
            "enabled": node.get("enabled", True),
            "error": None,
            "base_url": base,
        }
        if node.get("token"):
            out["auth"] = "bearer"  # surface that auth is configured (don't leak the token)
        return out
    except (urllib.error.URLError, OSError, TimeoutError) as e:
        out = {
            "name": node.get("name"),
            "host": node.get("host"),
            "protocol": proto,
            "model": node.get("model", ""),
            "ok": False,
            "latency_ms": round((time.time() - t0) * 1000, 1),
            "model_available": False,
            "enabled": node.get("enabled", True),
            "error": str(e)[:200],
            "base_url": base,
        }
        # Surface 401 hints clearly
        err_str = str(e)
        if "401" in err_str or "Unauthorized" in err_str:
            out["error"] = "401 Unauthorized — node requires auth but token is missing or wrong"
        if node.get("token"):
            out["auth"] = "bearer"
        return out


# =====================
# Routing + Ask (existing logic, refactored to use cfg)
# =====================
def normalize(text: str) -> str:
    nfkd = unicodedata.normalize("NFKD", text.lower())
    return "".join(c for c in nfkd if not unicodedata.combining(c))


def keyword_score(text: str, keywords: list) -> tuple:
    norm = normalize(text)
    matched = []
    for kw in keywords:
        nkw = normalize(kw)
        if re.search(r"(?:^|\W)" + re.escape(nkw) + r"(?:$|\W)", norm):
            matched.append(kw)
    return len(matched), matched


def route(text: str, cfg: dict) -> dict:
    """Keyword scoring for routing.

    Scoring:
    - code_keywords: terms that indicate code/programming tasks
    - chat_keywords: terms that indicate Q&A/explanation tasks
    - general_penalty: terms that indicate pure chitchat (e.g. "hola",
      "buenos días") — these bump the score to 0 so the ask goes to a
      general node if one is available.

    Returns: {routed_to, score_code, score_chat, score_general, matched_*}
    routed_to ∈ {code, chat, general, manual}
      - code:    any code keyword matched
      - chat:    chat keyword matched AND no code keyword
      - general: no keywords matched, but general node is available
      - manual:  no keywords matched AND no general node
    """
    code_kw = cfg.get("routing", {}).get("code_keywords", [])
    chat_kw = cfg.get("routing", {}).get("chat_keywords", [])
    gen_pen = cfg.get("routing", {}).get("general_penalty", [])

    norm = normalize(text)
    sc, mc = keyword_score(text, code_kw)
    sh, mh = keyword_score(text, chat_kw)
    sp, mp = keyword_score(text, gen_pen)

    # If penalty matches, it's small talk — don't trigger code or chat routing
    if sp > 0 and sc == 0 and sh == 0:
        picked = "general"
    elif sc > sh:
        picked = "code"
    elif sh > sc:
        picked = "chat"
    elif sc == 0 and sh == 0:
        picked = "general"  # fallback (was: manual)
    else:
        # tie — code wins (slave-b is faster, more deterministic)
        picked = "code"

    return {
        "routed_to": picked,
        "score_code": sc,
        "score_chat": sh,
        "score_general": sp,
        "matched_code": mc,
        "matched_chat": mh,
        "matched_general": mp,
    }


def ask_node(node: dict, text: str) -> dict:
    base = resolve_base_url(node)
    proto = node.get("protocol", "custom")
    timeout = node.get("timeout_s", 120)
    model = node.get("model", "")
    auth = _auth_headers(node)
    t0 = time.time()
    try:
        if proto == "ollama":
            url = _endpoint_url(base, "/api/chat")
            body = json.dumps({
                "model": model,
                "messages": [{"role": "user", "content": text}],
                "stream": False,
            }).encode()
        else:  # lmstudio, openai, or custom — all openai-compatible
            url = _endpoint_url(base, "/chat/completions")
            body = json.dumps({
                "model": model,
                "messages": [{"role": "user", "content": text}],
                "stream": False,
            }).encode()
        req = urllib.request.Request(url, data=body, headers={"Content-Type": "application/json", **auth})
        with urllib.request.urlopen(req, timeout=timeout) as r:
            payload = json.loads(r.read().decode())
        if proto == "ollama":
            content = payload.get("message", {}).get("content", "")
        else:
            content = payload.get("choices", [{}])[0].get("message", {}).get("content", "")
        latency = round(time.time() - t0, 2)
        return {"content": content, "latency_s": latency, "ok": True, "error": None}
    except (urllib.error.URLError, OSError, TimeoutError, json.JSONDecodeError, KeyError) as e:
        err = str(e)[:200]
        if "401" in err or "Unauthorized" in err:
            err = "401 Unauthorized — node requires auth but token is missing or wrong"
        return {"content": "", "latency_s": round(time.time() - t0, 2), "ok": False, "error": err}


# =====================
# Self-healing: auto-failover + self-log
# =====================
SELF_LOG_PATH = os.environ.get("CLUSTER_SELF_LOG", "/home/spids/cluster/data/self-log.jsonl")

def _log_self_event(event: dict) -> None:
    """Append a self-monitoring event to the JSONL log. Best-effort."""
    try:
        os.makedirs(os.path.dirname(SELF_LOG_PATH), exist_ok=True)
        with open(SELF_LOG_PATH, "a") as f:
            f.write(json.dumps({**event, "ts": int(time.time() * 1000)}) + "\n")
    except OSError:
        pass


def _candidate_fallback_nodes(node: dict, cfg: dict) -> list:
    """Return enabled nodes that could serve as fallback for `node`.
    Tries: (1) the node's own fallback_node if set, (2) any other
    enabled node with the same role, (3) any enabled node."""
    candidates = []
    fb = node.get("fallback_node")
    if fb:
        for n in cfg.get("node", []):
            if n.get("name") == fb and n.get("enabled", True):
                candidates.append(n)
                break
    role = node.get("role")
    for n in cfg.get("node", []):
        if n.get("name") == node.get("name"):
            continue
        if not n.get("enabled", True):
            continue
        if n not in candidates and n.get("role") == role:
            candidates.append(n)
    for n in cfg.get("node", []):
        if n.get("name") == node.get("name"):
            continue
        if not n.get("enabled", True):
            continue
        if n not in candidates:
            candidates.append(n)
    return candidates


def ask_node_with_failover(node: dict, text: str, cfg: dict) -> dict:
    """Call ask_node. If the node fails, automatically try fallback nodes.
    Returns a dict augmented with 'attempts' (list of {node, ok, error, latency_s})."""
    t0 = time.time()
    primary = ask_node(node, text)
    attempts = [{"node": node.get("name"), "ok": primary["ok"],
                 "error": primary.get("error"), "latency_s": primary["latency_s"]}]
    if primary["ok"]:
        _log_self_event({
            "kind": "ask",
            "node": node.get("name"),
            "ok": True,
            "latency_s": primary["latency_s"],
            "text_len": len(text),
        })
        return {**primary, "attempts": attempts, "failed_over": False}

    # Try fallbacks
    for fb_node in _candidate_fallback_nodes(node, cfg):
        fb = ask_node(fb_node, text)
        attempts.append({"node": fb_node.get("name"), "ok": fb["ok"],
                         "error": fb.get("error"), "latency_s": fb["latency_s"]})
        if fb["ok"]:
            _log_self_event({
                "kind": "ask_failover",
                "primary": node.get("name"),
                "succeeded_on": fb_node.get("name"),
                "primary_error": primary.get("error"),
                "latency_s": fb["latency_s"],
                "total_s": round(time.time() - t0, 2),
            })
            return {**fb, "attempts": attempts, "failed_over": True,
                    "primary_node": node.get("name")}

    # All failed
    _log_self_event({
        "kind": "ask_failed",
        "node": node.get("name"),
        "attempts": attempts,
        "text_len": len(text),
    })
    return {**primary, "attempts": attempts, "failed_over": False,
            "all_failed": True}


# =====================
# CLI subcommands
# =====================
def cmd_health(cfg: dict) -> int:
    out = {"cluster": cfg.get("meta", {}).get("name", "?"), "slaves": {}}
    for n in cfg.get("node", []):
        if n.get("enabled", True) is False:
            continue
        out["slaves"][n["name"]] = check_node(n)

    # Hindsight node (always reported, independent of node list)
    if HINDSIGHT_ENABLED:
        h = hindsight.health()
        stats = hindsight.stats()
        nc = stats.get("node_count", 0)
        out["slaves"]["hindsight"] = {
            "name": "hindsight",
            "host": "remote",
            "protocol": "hindsight",
            "model": f"{nc} nodes" if nc else "(empty)",
            "ok": h.get("ok", False),
            "latency_ms": h.get("latency_ms"),
            "model_available": h.get("ok", False),
            "enabled": True,
            "error": h.get("error"),
            "base_url": os.environ.get("HINDSIGHT_BASE", "http://127.0.0.1:8765"),
            "memory_stats": stats,
        }
    print(json.dumps(out, indent=2))
    return 0


def cmd_route(text: str, cfg: dict) -> int:
    print(json.dumps(route(text, cfg), indent=2))
    return 0


def _pick_node(cfg: dict, decision: dict) -> dict | None:
    """Pick a node from the cluster given a routing decision.

    Priority:
    1. First enabled node whose role matches the routing decision:
       - routed_to=code    -> role in {code_tools, general, master}
         (we try code_tools first, then fall back to general)
       - routed_to=chat    -> role in {chat_reflection, general, master}
       - routed_to=general -> role in {general, master, anything}
    2. If no role match, fall back to any enabled node (master > general > anything).
    3. If still nothing, return None.
    """
    picked = decision["routed_to"]
    role_priority = {
        "code":    ["code_tools", "general", "master"],
        "chat":    ["chat_reflection", "general", "master"],
        "general": ["general", "master", "chat_reflection", "code_tools"],
        "manual":  ["general", "master", "chat_reflection", "code_tools"],
    }.get(picked, ["master", "general"])

    nodes = [n for n in cfg.get("node", []) if n.get("enabled", True)]
    # First pass: match by role
    for role in role_priority:
        for n in nodes:
            if n.get("role") == role:
                return n
    # Second pass: any enabled node
    return nodes[0] if nodes else None


# =====================
# Master orchestration
# =====================
def should_decompose(text: str, cfg: dict) -> bool:
    """Decide whether an ask is long/complex enough to warrant splitting
    into subtasks. Heuristic: length + presence of multi-step language.

    Set CLUSTER_DECOMPOSE_DISABLED=1 to opt out (handy for ad-hoc testing).
    Set CLUSTER_DECOMPOSE_MIN_CHARS=NNN to tune the length threshold.
    """
    if os.environ.get("CLUSTER_DECOMPOSE_DISABLED") == "1":
        return False
    min_chars = int(os.environ.get("CLUSTER_DECOMPOSE_MIN_CHARS", "120"))
    if len(text) < min_chars:
        return False
    import re
    text_l = text.lower()
    # Multi-step signals (Spanish + English). Use regex with word boundaries
    # so "y luego" matches "Y luego, haz X" or ". Y luego, haz Y" both.
    patterns = [
        r"\bprimero\b", r"\bsegundo\b", r"\btercero\b",
        r"\bprimera\b", r"\bsegunda\b", r"\btercera\b",
        r"\bpaso\s*\d+\b", r"\bstep\s*\d+\b",
        r"\b1\)", r"\b2\)", r"\b3\)", r"\b4\)",
        r"\b\d+\.\s",          # "1. ", "2. ", etc.
        r"\b[Yy]\s+luego\b", r"\b[Yy]\s+despu[ée]s\b",
        r"\band then\b", r"\bfirst\b", r"\bsecond\b", r"\bthird\b",
        r"\b[aá]dem[aá]s\b", r"\basimismo\b", r"\bpor [uú]ltimo\b",
        r"\bfinally\b", r"\balso\b", r"\bnext\b", r"\bthen\b",
    ]
    n_signals = sum(1 for p in patterns if re.search(p, text_l))
    return n_signals >= 2


def cmd_ask_orchestrated(text: str, cfg: dict, decision: dict) -> int:
    """Master orchestrator: decompose → parallel run → synthesize.

    Steps:
    1. Plan: ask the fastest available node to split the ask into 2-4
       self-contained subtasks. The plan is JSON.
    2. Dispatch: route each subtask independently to the right slave
       and run them in parallel. The total wall time is roughly
       max(slave latencies), not the sum.
    3. Synthesize: ask the fastest node to merge the subtask answers
       into a single coherent response.
    """
    t_start = time.time()
    # Use the fastest enabled node for the meta-tasks (plan + synthesis).
    # Order: code_tools (lmstudio/qwen) is usually 3-10s; chat_reflection
    # (gemma4) is 30-90s. We pick whichever is faster.
    plan_node = _pick_fastest_node(cfg) or _pick_node_for_role(cfg, "chat_reflection")
    if not plan_node:
        # Fall back to single-ask path
        target = _pick_node(cfg, decision)
        if not target:
            print(json.dumps({"error": "no enabled node for orchestration", "routing": decision}, indent=2))
            return 1
        result = ask_node(target, text)
        return _finish_ask_log(text, decision, [target["name"]], result, [text], [result.get("content", "")], None, t_start)

    # Step 1: plan decomposition (use a low max_tokens to keep it fast)
    plan_prompt = build_plan_prompt(text)
    plan_result = _ask_node_quick(plan_node, plan_prompt, max_tokens=512)
    if not plan_result.get("ok"):
        # Fall back to single-ask path
        target = _pick_node(cfg, decision)
        if not target:
            print(json.dumps({"error": "no enabled node and planner failed", "planner_error": plan_result.get("error")}, indent=2))
            return 1
        result = ask_node(target, text)
        return _finish_ask_log(text, decision, [target["name"]], result, [text], [result.get("content", "")], None, t_start)

    subtasks = parse_subtask_plan(plan_result.get("content", ""))
    if not subtasks or len(subtasks) < 2:
        # Planner didn't produce a plan — fall through
        target = _pick_node(cfg, decision)
        if not target:
            print(json.dumps({"error": "planner returned no subtasks", "planner_response": plan_result.get("content", "")[:500]}, indent=2))
            return 1
        result = ask_node(target, text)
        return _finish_ask_log(text, decision, [target["name"]], result, [text], [result.get("content", "")], None, t_start)

    # Cap to 4 subtasks
    subtasks = subtasks[:4]
    log.info("orchestrator: plan returned %d subtasks", len(subtasks))

    # Step 2: parallel dispatch
    import concurrent.futures
    sub_results: list[tuple[dict, str, str, dict]] = []  # (node, sub, response, dispatch_decision)
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(subtasks)) as pool:
        futures = {}
        for sub in subtasks:
            sub_decision = route(sub, cfg)
            sub_node = _pick_node(cfg, sub_decision)
            if not sub_node:
                continue
            futures[pool.submit(ask_node, sub_node, sub)] = (sub_node, sub, sub_decision)
        for fut in concurrent.futures.as_completed(futures):
            node, sub, sub_decision = futures[fut]
            try:
                r = fut.result()
            except Exception as e:
                r = {"ok": False, "error": str(e), "content": "", "latency_s": 0}
            sub_results.append((node, sub, r, sub_decision))

    sub_results.sort(key=lambda x: x[0]["name"])  # stable order by node name
    sub_nodes = [n["name"] for n, _, _, _ in sub_results]
    sub_inputs = [s for _, s, _, _ in sub_results]
    sub_outputs = [r.get("content", "") for _, _, r, _ in sub_results]

    # Step 3: synthesize (reuse plan_node for speed, with bigger context)
    synth_prompt = build_synth_prompt(text, list(zip(sub_inputs, sub_outputs, sub_nodes)))
    synth_result = _ask_node_quick(plan_node, synth_prompt, max_tokens=2048)
    final_content = synth_result.get("content", "") if synth_result.get("ok") else synthesize_fallback(text, sub_inputs, sub_outputs, sub_nodes)

    # Build the orchestration result
    total_latency = round(time.time() - t_start, 2)
    out = {
        "ok": synth_result.get("ok", False) or any(r.get("ok") for _, _, r, _ in sub_results),
        "orchestrated": True,
        "subtasks": [
            {
                "node": n["name"],
                "routing": d.get("routed_to"),
                "input": s,
                "output": r.get("content", ""),
                "latency_s": r.get("latency_s"),
                "ok": r.get("ok", False),
                "error": r.get("error"),
            } for (n, s, r, d) in sub_results
        ],
        "synthesis_node": synth_node["name"],
        "synthesis_latency_s": synth_result.get("latency_s"),
        "content": final_content,
        "total_latency_s": total_latency,
        "latency_s": total_latency,
        "node": synth_node["name"],
        "model": synth_node.get("model"),
        "routing": decision,
        "plan_response": plan_result.get("content", "")[:500],
    }
    if synth_result.get("error"):
        out["synthesis_error"] = synth_result["error"]

    # Log orchestration
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOG_PATH.open("a") as f:
        from datetime import datetime
        f.write(f"{datetime.now().isoformat()} | ORCHESTRATED task={text[:120]!r} subtasks={sub_nodes} "
                f"plan_node={plan_node['name']} synth_node={synth_node['name']} "
                f"total_latency={total_latency}s\n")
        for (n, s, r, d) in sub_results:
            f.write(f"  {datetime.now().isoformat()} |   subtask slave={n['name']} "
                    f"routing={d.get('routed_to')} latency={r.get('latency_s')}s ok={r.get('ok')} "
                    f"input={s[:80]!r} output_preview={r.get('content','')[:120]!r}\n")

    # Hindsight remember
    if HINDSIGHT_ENABLED and out["ok"]:
        try:
            content = (
                f"USER ASK (ORCHESTRATED): {text}\n\n"
                f"SUBTASKS:\n" + "\n".join(f"- {s}" for s in sub_inputs) + "\n\n"
                f"FINAL RESPONSE:\n{final_content}"
            )
            mem_id = hindsight.remember(
                content,
                metadata={
                    "source": "spids-cluster",
                    "orchestrated": True,
                    "subtask_count": len(sub_inputs),
                    "subtask_nodes": sub_nodes,
                    "ts": int(time.time() * 1000),
                },
            )
            if mem_id:
                log.info("hindsight remember ok: %s", mem_id)
        except Exception as _e:
            log.warning("hindsight remember failed: %s", _e)

    print(json.dumps(out, indent=2))
    return 0 if out["ok"] else 1


def _pick_node_for_role(cfg: dict, role: str) -> dict | None:
    """Find the first enabled node with the given role."""
    for n in cfg.get("node", []):
        if n.get("enabled", True) and n.get("role") == role:
            return n
    return None


def _pick_fastest_node(cfg: dict) -> dict | None:
    """Return the enabled node best suited for orchestration meta-tasks.

    The planner and synthesizer run small, structured-output tasks where
    reasoning quality matters more than raw speed. We prefer
    chat_reflection (gemma4:12b-mlx on slave-a, which has thinking
    enabled and handles reasoning well) over code_tools (lmstudio, fast
    but less reliable at JSON output for meta-tasks).
    """
    nodes = [n for n in cfg.get("node", []) if n.get("enabled", True)]
    if not nodes:
        return None
    # Prefer chat_reflection (gemma4 with thinking) for the meta-tasks
    for role in ("chat_reflection", "general", "code_tools", "master"):
        for n in nodes:
            if n.get("role") == role:
                return n
    return nodes[0]


def _ask_node_quick(node: dict, text: str, max_tokens: int = 1024) -> dict:
    """Like ask_node but with explicit max_tokens cap for the orchestration
    meta-tasks (plan and synthesis) where we want a fast, focused response
    rather than a long-form answer."""
    base = resolve_base_url(node)
    proto = node.get("protocol", "custom")
    timeout = node.get("timeout_s", 120)
    model = node.get("model", "")
    auth = _auth_headers(node)
    t0 = time.time()
    try:
        if proto == "ollama":
            url = _endpoint_url(base, "/api/chat")
            body = json.dumps({
                "model": model,
                "messages": [{"role": "user", "content": text}],
                "stream": False,
                "options": {"num_predict": max_tokens},
            }).encode()
        else:
            url = _endpoint_url(base, "/chat/completions")
            body = json.dumps({
                "model": model,
                "messages": [{"role": "user", "content": text}],
                "stream": False,
                "max_tokens": max_tokens,
            }).encode()
        req = urllib.request.Request(url, data=body, headers={"Content-Type": "application/json", **auth})
        with urllib.request.urlopen(req, timeout=timeout) as r:
            payload = json.loads(r.read().decode())
        if proto == "ollama":
            content = payload.get("message", {}).get("content", "")
        else:
            content = payload.get("choices", [{}])[0].get("message", {}).get("content", "")
        latency = round(time.time() - t0, 2)
        # Cache latency for future _pick_fastest_node calls
        node["last_latency_ms"] = int(latency * 1000)
        return {"content": content, "latency_s": latency, "ok": True, "error": None}
    except (urllib.error.URLError, OSError, TimeoutError, json.JSONDecodeError, KeyError) as e:
        err = str(e)[:200]
        if "401" in err or "Unauthorized" in err:
            err = "401 Unauthorized — node requires auth but token is missing or wrong"
        return {"content": "", "latency_s": round(time.time() - t0, 2), "ok": False, "error": err}


def _finish_ask_log(text, decision, nodes, result, sub_inputs, sub_outputs, synth_node, t_start):
    """Helper to log a non-orchestrated ask that was used as fallback."""
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOG_PATH.open("a") as f:
        from datetime import datetime
        f.write(f"{datetime.now().isoformat()} | FALLBACK_SIMPLE_ASK slave={nodes[0]} "
                f"latency={result.get('latency_s')}s routing={decision} task={text[:120]!r}\n")
    out = {
        "ok": result.get("ok", False),
        "orchestrated": False,
        "content": result.get("content", ""),
        "latency_s": result.get("latency_s"),
        "node": nodes[0] if nodes else None,
        "model": result.get("model"),
        "routing": decision,
        "error": result.get("error"),
    }
    print(json.dumps(out, indent=2))
    return 0 if out["ok"] else 1


def build_plan_prompt(user_text: str) -> str:
    """Build the prompt that asks the planning LLM to decompose the task."""
    return (
        "You are a master orchestrator. Break the user's task into 2-4 self-contained "
        "subtasks. Each subtask goes to either code_tools or chat_reflection.\n\n"
        "Output JSON only:\n"
        '{"subtasks": [{"task": "..."}, {"task": "..."}]}\n\n'
        "Each task is self-contained (don't reference 'previous answer'). Fewer than "
        "2 means the task is simple. Order matters (earlier ones first).\n\n"
        f"TASK: {user_text}\n"
        "JSON:"
    )


def build_synth_prompt(user_text: str, sub_results: list) -> str:
    """Build the prompt that asks the LLM to consolidate subtask answers."""
    parts = []
    for i, (sub_in, sub_out, node) in enumerate(sub_results, 1):
        parts.append(f"### {i} ({node}): {sub_in}\n{sub_out}\n")
    sub_block = "\n".join(parts)
    return (
        "You are a master synthesizer. Combine the subtask answers below into ONE "
        "clear final response. Keep code blocks intact. Don't mention the orchestration.\n\n"
        f"QUESTION: {user_text}\n\n"
        f"ANSWERS:\n{sub_block}\n\n"
        "FINAL:"
    )


def synthesize_fallback(user_text, sub_inputs, sub_outputs, sub_nodes):
    """If the synthesis node fails, concatenate the subtask answers with light framing."""
    parts = []
    for i, (sub_in, sub_out, node) in enumerate(zip(sub_inputs, sub_outputs, sub_nodes), 1):
        parts.append(f"## Subtask {i} ({node}): {sub_in}\n\n{sub_out}\n")
    return "\n\n---\n\n".join(parts)


def parse_subtask_plan(content: str) -> list[str]:
    """Extract a list of self-contained subtask strings from the planner LLM.
    Tolerant: handles JSON with or without 'why_code' fields, with code fences,
    or with leading prose. Falls back to empty list if nothing usable."""
    if not content:
        return []
    import re
    text = content.strip()
    # Strip ```json fences if present
    fence_m = re.search(r"```(?:json)?\s*(\{.*?\})\s*```", text, re.DOTALL)
    if fence_m:
        text = fence_m.group(1)
    # Try strict parse
    try:
        obj = json.loads(text)
        if isinstance(obj, dict) and isinstance(obj.get("subtasks"), list):
            tasks = []
            for st in obj["subtasks"]:
                if isinstance(st, dict) and st.get("task"):
                    tasks.append(str(st["task"]))
                elif isinstance(st, str):
                    tasks.append(st)
            return [t for t in tasks if t.strip()]
    except (ValueError, AttributeError):
        pass
    # Try to find a JSON object in the text
    obj_m = re.search(r"\{[^{}]*\"subtasks\"[^{}]*\[.*?\][^{}]*\}", text, re.DOTALL)
    if obj_m:
        try:
            obj = json.loads(obj_m.group(0))
            if isinstance(obj, dict) and isinstance(obj.get("subtasks"), list):
                return [str(st.get("task") if isinstance(st, dict) else st) for st in obj["subtasks"]]
        except ValueError:
            pass
    return []


def cmd_ask(text: str, cfg: dict) -> int:
    decision = route(text, cfg)
    target = _pick_node(cfg, decision)
    if target is None:
        result = {"error": "no enabled node in cluster", "routing": decision}
        print(json.dumps(result, indent=2))
        return 1

    # === Master orchestration: split long tasks into subtasks =============
    # If the ask is long/complex enough, decompose it into 2-4 subtasks,
    # run them in parallel across the right slaves, then synthesize the
    # final answer. Otherwise fall through to the single-ask path.
    if should_decompose(text, cfg):
        return cmd_ask_orchestrated(text, cfg, decision)

    result = ask_node_with_failover(target, text, cfg)
    # Pick the actual node that served the request (may differ from target if failover)
    served_node_name = result.get("node") or target["name"]
    if served_node_name != target["name"]:
        # Find the served node's config for logging
        served_node = next((n for n in cfg.get("node", []) if n.get("name") == served_node_name), target)
    else:
        served_node = target
    log_line = (
        f"slave={served_node_name} (target={target['name']}) "
        f"model={served_node.get('model', '?')} "
        f"latency={result['latency_s']}s failed_over={result.get('failed_over', False)} "
        f"all_failed={result.get('all_failed', False)} routing={decision} "
        f"task={text[:120]!r} preview={result.get('content','')[:200]!r}"
    )
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOG_PATH.open("a") as f:
        from datetime import datetime
        f.write(f"{datetime.now().isoformat()} | {log_line}\n")
    out = {
        "routing": decision,
        "node": served_node_name,
        "target_node": target["name"],
        "host": served_node.get("host"),
        "model": served_node.get("model"),
        "content": result.get("content", ""),
        "latency_s": result.get("latency_s"),
        "ok": result.get("ok"),
        "error": result.get("error"),
        "failed_over": result.get("failed_over", False),
        "attempts": result.get("attempts", []),
    }
    print(json.dumps(out, indent=2))

    # Auto-remember: write user prompt + assistant response to Hindsight on success.
    # Fire-and-forget — if Hindsight is unreachable, log and move on.
    if HINDSIGHT_ENABLED and result.get("ok"):
        try:
            content = (
                f"USER ASK: {text}\n\n"
                f"ROUTING: {decision.get('routed_to')} → {target['name']} ({target.get('model')})\n"
                f"LATENCY: {result.get('latency_s')}s\n\n"
                f"ASSISTANT RESPONSE:\n{result.get('content', '')}"
            )
            mem_id = hindsight.remember(
                content,
                metadata={
                    "source": "spids-cluster",
                    "node": target["name"],
                    "model": target.get("model"),
                    "routed_via": decision.get("routed_to"),
                    "score_code": decision.get("score_code", 0),
                    "score_chat": decision.get("score_chat", 0),
                    "matched_code": decision.get("matched_code", []),
                    "matched_chat": decision.get("matched_chat", []),
                    "latency_s": result.get("latency_s"),
                    "ts": int(time.time() * 1000),
                },
            )
            if mem_id:
                log.info("hindsight remember ok: %s", mem_id)
            else:
                log.debug("hindsight remember skipped (unreachable or error)")
        except Exception as _e:
            log.warning("hindsight remember failed: %s", _e)

    return 0 if result.get("ok") else 1


def cmd_nodes_list(cfg: dict) -> int:
    nodes = cfg.get("node", [])
    # Annotate each with live health
    out = []
    for n in nodes:
        info = {**n, "health": check_node(n) if n.get("enabled", True) else {"ok": None, "error": "disabled"}}
        out.append(info)
    print(json.dumps({"cluster": cfg.get("meta", {}).get("name", "?"), "count": len(out), "nodes": out}, indent=2))
    return 0


def cmd_nodes_get(name: str, cfg: dict) -> int:
    n = get_node(cfg, name)
    if n is None:
        print(json.dumps({"error": f"node {name!r} not found"}))
        return 1
    info = {**n, "health": check_node(n) if n.get("enabled", True) else {"ok": None}}
    print(json.dumps(info, indent=2))
    return 0


def cmd_nodes_add(args, cfg: dict) -> int:
    try:
        node = add_node(cfg,
                        name=args.name,
                        host=args.host,
                        port=args.port,
                        base_url=args.base_url,
                        protocol=args.protocol,
                        model=args.model,
                        role=args.role,
                        timeout_s=args.timeout_s,
                        enabled=not args.disabled,
                        token=args.token)
    except ValueError as e:
        print(json.dumps({"error": str(e)}))
        return 1
    out = {"added": node, "health": check_node(node) if node.get("enabled", True) else None}
    # Don't echo the token in stdout
    if "token" in out["added"]:
        out["added"] = {**out["added"], "token": "***" + out["added"]["token"][-4:] if out["added"]["token"] else ""}
    print(json.dumps(out, indent=2))
    return 0


def cmd_nodes_remove(name: str, cfg: dict) -> int:
    if not remove_node(cfg, name):
        print(json.dumps({"error": f"node {name!r} not found"}))
        return 1
    print(json.dumps({"removed": name}))
    return 0


def cmd_nodes_enable(name: str, enabled: bool, cfg: dict) -> int:
    n = set_node_enabled(cfg, name, enabled)
    if n is None:
        print(json.dumps({"error": f"node {name!r} not found"}))
        return 1
    print(json.dumps({"updated": n}, indent=2))
    return 0


# =====================
# Self-tuning: analyze self-log and propose config changes
# =====================
def _load_self_events(window_hours: int = 24) -> list:
    """Load self-log events from the last `window_hours` hours."""
    if not os.path.exists(SELF_LOG_PATH):
        return []
    cutoff = int((time.time() - window_hours * 3600) * 1000)
    events = []
    try:
        with open(SELF_LOG_PATH) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    ev = json.loads(line)
                    if ev.get("ts", 0) >= cutoff:
                        events.append(ev)
                except json.JSONDecodeError:
                    continue
    except OSError:
        pass
    return events


def _confidence_from_samples(n: int, divisor: int = 20) -> float:
    """Map sample count to a 0..1 confidence score.
    0 samples -> 0.0, 1 sample -> 0.1, divisor samples -> ~0.86, 2*divisor -> ~0.98."""
    if n <= 0:
        return 0.0
    return round(1.0 - 0.5 ** (n / divisor), 3)


def _build_proposals(events: list, cfg: dict) -> list:
    """Generate a list of tuning proposals based on self-log evidence."""
    proposals = []

    # === 0) Repeated failover from a primary ===============================
    # If a node fails N+ times in a row (all routed to fallbacks), suggest
    # either disabling it (high risk) or setting a healthier primary.
    failovers_by_primary = {}
    for e in events:
        if e.get("kind") == "ask_failover":
            p = e.get("primary")
            if p:
                failovers_by_primary[p] = failovers_by_primary.get(p, 0) + 1
    for prim, count in failovers_by_primary.items():
        if count >= 3:
            conf = _confidence_from_samples(count, divisor=10)
            prim_node = next((n for n in cfg.get("node", []) if n.get("name") == prim), None)
            if not prim_node:
                continue
            # Suggest setting the most-recently-successful fallback as the
            # recommended replacement or just disabling
            recent_succs = [e.get("succeeded_on") for e in events
                            if e.get("kind") == "ask_failover" and e.get("primary") == prim]
            succ_count = {}
            for s in recent_succs:
                if s:
                    succ_count[s] = succ_count.get(s, 0) + 1
            top_succ = max(succ_count.items(), key=lambda x: x[1])[0] if succ_count else None
            desc = (
                f"`{prim}` failed {count} times in the last 24h. "
                + (f"Most asks succeeded on `{top_succ}`. " if top_succ else "")
                + "Consider disabling this node or replacing it."
            )
            proposals.append({
                "id": f"primary-failing-{prim}",
                "kind": "set_node_enabled",
                "target_node": prim,
                "value": False,
                "evidence": {
                    "failover_count": count,
                    "fallback_succeeded": succ_count,
                },
                "description": desc,
                "confidence": conf,
                "risk": "high",
                "auto_apply": False,
            })

    # === 1) Per-node latency comparison (rebalancing suggestion) ===========
    # Group events by node. For ask events, attribute to e["node"] (the
    # actual server). For ask_failover events, attribute to the primary
    # (which had the high latency / error), not the failover target.
    by_node_primary = {}  # for slow-node analysis (which node is slow)
    by_node_actual = {}   # for fast-node analysis (which node IS the workhorse)
    for e in events:
        kind = e.get("kind")
        n = e.get("node")
        if kind == "ask" and n:
            by_node_primary.setdefault(n, []).append(e)
            by_node_actual.setdefault(n, []).append(e)
        elif kind == "ask_failover":
            primary = e.get("primary")
            succ = e.get("succeeded_on")
            if primary:
                # The primary was slow/failed; if it had a partial latency, count it
                by_node_primary.setdefault(primary, []).append(e)
            if succ:
                by_node_actual.setdefault(succ, []).append(e)

    # Need at least 2 nodes with data to compare
    if len(by_node_actual) >= 2:
        node_stats = []
        for n, evs in by_node_actual.items():
            lats = [e.get("latency_s", 0) for e in evs if e.get("ok") is not False and e.get("latency_s")]
            # For failover events, latency is the failover node's latency (so the
            # 'actual' for that node is fast). For primary, latency is the slow one.
            if lats:
                node_stats.append({"node": n, "avg": sum(lats) / len(lats), "samples": len(lats)})
        if len(node_stats) >= 2:
            node_stats.sort(key=lambda x: x["avg"])
            fastest = node_stats[0]
            slowest = node_stats[-1]
            if slowest["avg"] > fastest["avg"] * 1.5:
                slowest_node = next((n for n in cfg.get("node", []) if n.get("name") == slowest["node"]), None)
                if slowest_node:
                    current_fb = slowest_node.get("fallback_node", "")
                    if current_fb != fastest["node"]:
                        conf = _confidence_from_samples(min(fastest["samples"], slowest["samples"]))
                        proposals.append({
                            "id": f"rebalance-{slowest['node']}-to-{fastest['node']}",
                            "kind": "set_fallback_node",
                            "target_node": slowest["node"],
                            "value": fastest["node"],
                            "evidence": {
                                "slowest": slowest,
                                "fastest": fastest,
                                "ratio": round(slowest["avg"] / fastest["avg"], 2),
                            },
                            "description": (
                                f"Set `{fastest['node']}` as fallback for `{slowest['node']}`. "
                                f"`{slowest['node']}` averages {slowest['avg']:.2f}s vs "
                                f"`{fastest['node']}` at {fastest['avg']:.2f}s "
                                f"({slowest['avg'] / fastest['avg']:.1f}x slower) "
                                f"over {min(fastest['samples'], slowest['samples'])} samples."
                            ),
                            "confidence": conf,
                            "risk": "low",
                            "auto_apply": conf >= 0.8 and slowest["samples"] >= 30,
                        })

    # === 2) High failure rate per node =====================================
    for n in cfg.get("node", []):
        name = n.get("name")
        node_events = [e for e in events if e.get("node") == name and e.get("kind") == "ask"]
        fails = [e for e in node_events if not e.get("ok")]
        if not node_events:
            continue
        rate = len(fails) / len(node_events)
        if rate > 0.2 and len(node_events) >= 5:
            conf = _confidence_from_samples(len(node_events), divisor=15)
            proposals.append({
                "id": f"disable-{name}",
                "kind": "set_node_enabled",
                "target_node": name,
                "value": False,
                "evidence": {
                    "failure_rate": round(rate, 3),
                    "failures": len(fails),
                    "total": len(node_events),
                    "sample_errors": [e.get("error", "")[:80] for e in fails[:3]],
                },
                "description": (
                    f"Disable `{name}` — it has {rate * 100:.0f}% failure rate "
                    f"({len(fails)}/{len(node_events)} fails). "
                    f"Sample errors: {fails[0].get('error', '')[:80] if fails else 'n/a'}"
                ),
                "confidence": conf,
                "risk": "high",
                "auto_apply": False,  # never auto-disable without human review
            })

    # === 3) Overloaded node: high failover count suggests adding capacity ==
    failovers_to = {}
    for e in events:
        if e.get("kind") == "ask_failover":
            succ = e.get("succeeded_on")
            if succ:
                failovers_to[succ] = failovers_to.get(succ, 0) + 1
    for succ_name, count in failovers_to.items():
        if count >= 5:
            conf = _confidence_from_samples(count, divisor=10)
            succ_node = next((n for n in cfg.get("node", []) if n.get("name") == succ_name), None)
            if succ_node:
                proposals.append({
                    "id": f"overload-{succ_name}",
                    "kind": "investigate_capacity",
                    "target_node": succ_name,
                    "value": None,
                    "evidence": {
                        "failover_count": count,
                        "failovers_received": count,
                    },
                    "description": (
                        f"`{succ_name}` is handling {count} failover requests in the last 24h. "
                        f"Consider adding another node with the same role to distribute load."
                    ),
                    "confidence": conf,
                    "risk": "low",
                    "auto_apply": False,  # suggestions only
                })

    # === 4) Upgrades: proactive improvements based on observed patterns =====
    # These are SUGGESTIONS only (not auto-apply) — the LLM master
    # reviews and decides. They push the cluster to be BETTER, not just
    # patch over issues.
    upgrades = []

    # Pre-compute node_latencies for all upgrade checks
    node_latencies = []
    if len(by_node_actual) >= 2:
      for n, evs in by_node_actual.items():
        lats = [e.get("latency_s", 0) for e in evs if e.get("ok") is not False and e.get("latency_s")]
        if lats:
          node_latencies.append((n, sum(lats) / len(lats), len(lats)))
      if len(node_latencies) >= 2:
        node_latencies.sort(key=lambda x: x[1])
        slowest = node_latencies[-1]
        # Already has fallback proposal for this; suggest one if absent
        slowest_node = next((n for n in cfg.get("node", []) if n.get("name") == slowest[0]), None)
        if slowest_node and not slowest_node.get("fallback_node") and slowest[2] >= 5:
          conf = _confidence_from_samples(slowest[2], divisor=15)
          upgrades.append({
            "id": f"add-fallback-to-{slowest[0]}",
            "kind": "set_fallback_node",
            "target_node": slowest[0],
            "value": node_latencies[0][0],  # fastest
            "evidence": {
                "slowest": {"node": slowest[0], "avg": slowest[1], "samples": slowest[2]},
                "fastest": node_latencies[0][0],
            },
            "description": f"Upgrade: `{slowest[0]}` averages {slowest[1]:.1f}s but has no fallback. Add `{node_latencies[0][0]}` as a fallback for resilience.",
            "confidence": conf,
            "risk": "low",
            "auto_apply": False,  # Suggestions only — master reviews
          })

    # (b) Old / outdated fallback_node pointing to a slower node
    # If node X's fallback_node is slower than another enabled node, suggest
    # upgrading the fallback to the faster node.
    for n in cfg.get("node", []):
      if not n.get("enabled", True): continue
      current_fb = n.get("fallback_node")
      if not current_fb: continue
      # Find current avg latency
      this_lat = next((avg for nm, avg, _ in node_latencies if nm == n["name"]), None)
      fb_lat = next((avg for nm, avg, _ in node_latencies if nm == current_fb), None)
      if this_lat and fb_lat and fb_lat > this_lat * 1.5:
        # Find a faster node
        faster = next((nm for nm, avg, _ in node_latencies
                      if nm != n["name"] and avg < this_lat and nm != current_fb), None)
        if faster and faster != current_fb:
          upgrades.append({
            "id": f"upgrade-fallback-of-{n['name']}",
            "kind": "set_fallback_node",
            "target_node": n["name"],
            "value": faster,
            "evidence": {
                "current_fallback": current_fb,
                "current_fb_avg": fb_lat,
                "this_node_avg": this_lat,
                "proposed_fallback": faster,
            },
            "description": f"Upgrade: `{n['name']}`'s fallback (`{current_fb}`) averages {fb_lat:.1f}s, slower than the primary ({this_lat:.1f}s). Better fallback: `{faster}`.",
            "confidence": _confidence_from_samples(slowest[2] if len(node_latencies) > 1 else 5, divisor=20),
            "risk": "low",
            "auto_apply": False,
          })

    # (c) No fallback at all (resilience upgrade)
    for n in cfg.get("node", []):
      if not n.get("enabled", True): continue
      if n.get("fallback_node"): continue
      # Find a healthy node of any role
      healthy = next((m for m in cfg.get("node", [])
                     if m.get("name") != n.get("name") and m.get("enabled", True)), None)
      if healthy:
        # We don't suggest a specific one — let the master decide
        upgrades.append({
          "id": f"add-fallback-to-{n['name']}",
          "kind": "set_fallback_node",
          "target_node": n["name"],
          "value": healthy["name"],
          "evidence": {"reason": "no fallback configured"},
          "description": f"Upgrade: `{n['name']}` has no fallback_node. Resilience: set fallback to `{healthy['name']}` so asks can be retried if `{n['name']}` fails.",
          "confidence": 0.5,
          "risk": "low",
          "auto_apply": False,
        })

    # (d) Single-node hot spot → propose adding another node of the same role
    for n in cfg.get("node", []):
      if not n.get("enabled", True): continue
      role = n.get("role")
      # Count asks handled by this role
      role_asks = sum(1 for evs in by_node_actual.values() for e in evs)
      this_node_asks = sum(len(evs) for nm, evs in by_node_actual.items() if nm == n["name"])
      # If this node handles >80% of role traffic, suggest adding another
      if this_node_asks >= 10 and role_asks > 0 and this_node_asks / role_asks > 0.8:
        upgrades.append({
          "id": f"hot-spot-{n['name']}-role-{role}",
          "kind": "investigate_capacity",
          "target_node": n["name"],
          "value": None,
          "evidence": {
            "this_node_asks": this_node_asks,
            "role_total_asks": role_asks,
            "concentration_pct": round(this_node_asks / role_asks * 100, 1),
          },
          "description": f"Upgrade: `{n['name']}` handles {this_node_asks / role_asks * 100:.0f}% of role={role} traffic. Consider adding another node of the same role for capacity.",
          "confidence": 0.5,
          "risk": "low",
          "auto_apply": False,
        })

    # (e) Tighter interval if asks are spiking (or looser if quiet)
    asks_last_24h = sum(1 for evs in by_node_actual.values() for e in evs)
    if asks_last_24h > 200:
      upgrades.append({
        "id": "consider-lower-interval",
        "kind": "set_interval",
        "target_node": "master",
        "value": 3,  # down from 5min
        "evidence": {"asks_last_24h": asks_last_24h},
        "description": f"Upgrade: high ask volume ({asks_last_24h}/24h). Consider tightening auto-tune interval from 5min to 3min to catch issues faster.",
        "confidence": 0.4,
        "risk": "low",
        "auto_apply": False,
      })
    elif asks_last_24h < 5 and len(events) > 20:
      upgrades.append({
        "id": "consider-higher-interval",
        "kind": "set_interval",
        "target_node": "master",
        "value": 10,  # up from 5min
        "evidence": {"asks_last_24h": asks_last_24h},
        "description": f"Upgrade: low ask volume ({asks_last_24h}/24h) but many self-log events. Consider loosening interval from 5min to 10min to reduce overhead.",
        "confidence": 0.4,
        "risk": "low",
        "auto_apply": False,
      })

    # (f) Heuristic: model swap to a faster/newer one
    # We don't know what models are available on each slave — that's a
    # decision for the master. So we just suggest "consider rotating the
    # model" if the current one is consistently slow.
    for n in cfg.get("node", []):
      if not n.get("enabled", True): continue
      this_lat = next((avg for nm, avg, _ in node_latencies if nm == n["name"]), None)
      this_samples = next((s for nm, _, s in node_latencies if nm == n["name"]), 0)
      if this_lat and this_samples >= 5 and this_lat > 15:
        upgrades.append({
          "id": f"consider-rotating-model-on-{n['name']}",
          "kind": "investigate_capacity",
          "target_node": n["name"],
          "value": None,
          "evidence": {"avg_latency_s": this_lat, "samples": this_samples, "current_model": n.get("model", "?")},
          "description": f"Upgrade: `{n['name']}` averages {this_lat:.1f}s per ask with model `{n.get('model', '?')}`. Consider rotating to a faster model (master review needed for the new model name).",
          "confidence": 0.5,
          "risk": "low",
          "auto_apply": False,
        })

    # Replace the existing per-node latency suggestion with the
    # richer upgrades array. We append upgrades to the regular proposals.
    # (We do NOT replace the originals because they are reactive fixes.)
    return proposals + upgrades


def _apply_proposal(proposal: dict, cfg: dict) -> tuple:
    """Apply a single proposal to cfg in memory. Returns (ok, message)."""
    kind = proposal.get("kind")
    if kind == "set_fallback_node":
        for n in cfg.get("node", []):
            if n.get("name") == proposal.get("target_node"):
                n["fallback_node"] = proposal.get("value", "")
                return True, f"set fallback_node={proposal['value']!r} on {n['name']!r}"
        return False, f"node {proposal.get('target_node')!r} not found"
    elif kind == "set_node_enabled":
        for n in cfg.get("node", []):
            if n.get("name") == proposal.get("target_node"):
                n["enabled"] = bool(proposal.get("value"))
                return True, f"set enabled={n['enabled']} on {n['name']!r}"
        return False, f"node {proposal.get('target_node')!r} not found"
    else:
        return False, f"unsupported proposal kind: {kind!r}"


def cmd_insights(cfg: dict, window_hours: int = 24, auto_apply: bool = False) -> int:
    """Analyze the self-log and print tuning proposals as JSON.
    With auto_apply=True, high-confidence low-risk proposals are applied
    to cluster.toml in-place and the changes are recorded in the self-log."""
    events = _load_self_events(window_hours)
    proposals = _build_proposals(events, cfg)

    applied = []
    skipped = []
    if auto_apply:
        for p in proposals:
            if p.get("auto_apply"):
                ok, msg = _apply_proposal(p, cfg)
                if ok:
                    save_config(cfg)
                    _log_self_event({
                        "kind": "tune_applied",
                        "proposal_id": p["id"],
                        "target": p.get("target_node"),
                        "change": p.get("kind"),
                        "value": p.get("value"),
                        "confidence": p.get("confidence"),
                    })
                    applied.append({"id": p["id"], "message": msg})
                else:
                    skipped.append({"id": p["id"], "message": msg})
        # Re-build proposals list to show updated state
        if applied:
            proposals = _build_proposals(_load_self_events(window_hours), cfg)

    out = {
        "ok": True,
        "window_hours": window_hours,
        "events_analyzed": len(events),
        "proposals": proposals,
        "applied": applied,
        "skipped": skipped,
    }
    print(json.dumps(out, indent=2))
    return 0


def cmd_tune_apply(proposal_id: str, cfg: dict) -> int:
    """Apply a single proposal by id."""
    events = _load_self_events(24)
    proposals = _build_proposals(events, cfg)
    target = next((p for p in proposals if p.get("id") == proposal_id), None)
    if not target:
        print(json.dumps({"ok": False, "error": f"proposal {proposal_id!r} not found"}))
        return 1
    ok, msg = _apply_proposal(target, cfg)
    if ok:
        save_config(cfg)
        _log_self_event({
            "kind": "tune_applied",
            "proposal_id": proposal_id,
            "target": target.get("target_node"),
            "change": target.get("kind"),
            "value": target.get("value"),
            "confidence": target.get("confidence"),
        })
        print(json.dumps({"ok": True, "applied": target, "message": msg}, indent=2))
        return 0
    print(json.dumps({"ok": False, "error": msg}))
    return 1


# =====================
# Main
# =====================
def main() -> int:
    p = argparse.ArgumentParser(prog="clusterctl", description="spids dev cluster orchestrator")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("health", help="ping every enabled node")
    pr = sub.add_parser("route", help="classify a task without sending")
    pr.add_argument("text")
    pa = sub.add_parser("ask", help="route + send to a node")
    pa.add_argument("text")

    # insights (self-tuning)
    pi = sub.add_parser("insights", help="analyze self-log and propose tuning changes")
    pi.add_argument("--window-hours", type=int, default=24)
    pi.add_argument("--auto-apply", action="store_true",
                   help="apply high-confidence low-risk proposals without asking")

    # tune (apply a specific proposal)
    pt = sub.add_parser("tune", help="apply a specific tuning proposal")
    pt.add_argument("proposal_id")

    # nodes subcommands
    pn = sub.add_parser("nodes", help="manage cluster nodes")
    pns = pn.add_subparsers(dest="nodes_cmd", required=True)
    pns.add_parser("list", help="list all nodes + health")
    png = pns.add_parser("get", help="show one node")
    png.add_argument("name")
    pna = pns.add_parser("add", help="add a new node")
    pna.add_argument("name", help="unique node name")
    pna.add_argument("--host", default="127.0.0.1")
    pna.add_argument("--port", type=int, default=0, help="port (optional)")
    pna.add_argument("--base-url", default="", help="full base URL (overrides host+port)")
    pna.add_argument("--protocol", default="ollama", choices=sorted(VALID_PROTOCOLS))
    pna.add_argument("--model", default="")
    pna.add_argument("--role", default="general", choices=sorted(VALID_ROLES))
    pna.add_argument("--timeout-s", type=int, default=120)
    pna.add_argument("--token", default="", help="optional API token (Bearer auth) for protected nodes")
    pna.add_argument("--disabled", action="store_true", help="add but don't enable")
    pnr = pns.add_parser("remove", help="delete a node")
    pnr.add_argument("name")
    pne = pns.add_parser("enable", help="enable a node")
    pne.add_argument("name")
    pnd = pns.add_parser("disable", help="disable a node")
    pnd.add_argument("name")

    args = p.parse_args()
    cfg = load_config()

    if args.cmd == "health":
        return cmd_health(cfg)
    elif args.cmd == "route":
        return cmd_route(args.text, cfg)
    elif args.cmd == "ask":
        return cmd_ask(args.text, cfg)
    elif args.cmd == "insights":
        return cmd_insights(cfg, args.window_hours, args.auto_apply)
    elif args.cmd == "tune":
        return cmd_tune_apply(args.proposal_id, cfg)
    elif args.cmd == "nodes":
        if args.nodes_cmd == "list":
            return cmd_nodes_list(cfg)
        elif args.nodes_cmd == "get":
            return cmd_nodes_get(args.name, cfg)
        elif args.nodes_cmd == "add":
            return cmd_nodes_add(args, cfg)
        elif args.nodes_cmd == "remove":
            return cmd_nodes_remove(args.name, cfg)
        elif args.nodes_cmd == "enable":
            return cmd_nodes_enable(args.name, True, cfg)
        elif args.nodes_cmd == "disable":
            return cmd_nodes_enable(args.name, False, cfg)
    return 2


if __name__ == "__main__":
    sys.exit(main())
